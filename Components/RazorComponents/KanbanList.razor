@using System.Text.RegularExpressions

<tr>
    <td style="font-weight:600;max-width:180px;word-break:break-word">@CurrentCard.Nome</td>
    <td><span class="badge b-area">@(DbContext.GetByIndex<Setor>("Setores", CurrentCard.IndexSetor)!.Nome)</span></td>
    <td style="white-space:nowrap">@NormalizarTexto(CurrentCard.CurrentStatus.ToString())</td>
    <td><span class="badge b-@GetPrioridade(CurrentCard.Prioridade)">@CurrentCard.Prioridade</span></td>
    <td style="overflow-x: hidden; white-space:nowrap; text-overflow: ellipsis; max-width:160px">@(DbContext.GetByIndex<Responsavel>("Responsaveis", CurrentCard.IndexResponsavel)!.Nome ?? "-")</td>
    <td style="font-size:12px;color:var(--text2);max-width:160px;word-break:break-word">—</td>
    <td><span style="font-family:'DM Mono',monospace;font-size:12px;">—</span></td>
    <td><span style="font-family:'DM Mono',monospace;font-size:12px">@CardsManager.GetElapsedTimeByCardId(CurrentCard.Id)d</span></td>
    <td style=";font-size:12px;white-space:nowrap">—</td>
    <td>
    <div class="prog-bar" style="width:60px;display:inline-block;vertical-align:middle"><div class="prog-fill" style="width:0%"></div></div>
    <span style="font-size:11px;color:var(--text3);font-family:'DM Mono',monospace;margin-left:4px">0%</span>
    </td>
    <td><button class="btn icon sm" onclick="editProject(1)" title="Editar"><i class="ti ti-edit"></i></button></td>
</tr>

@code
{
    [Parameter]
    public string? CardId { get; set; }
    public Card CurrentCard = new Card();
    protected override void OnParametersSet()
    {
        if(!string.IsNullOrEmpty(CardId))
            CurrentCard = CardsManager.GetCardById(CardId)!;
    }
    string GetPrioridade(Prioridade p)
    {
        switch(p)
        {
            case Prioridade.Alta: return "alta";
            case Prioridade.Media: return "media";
            case Prioridade.Baixa: return "baixa";
            default: return "";
        }
    }
    string NormalizarTexto(string txt)
    {
        return Regex.Replace(txt, @"([a-z])([A-Z])", "$1 $2");
    }
}