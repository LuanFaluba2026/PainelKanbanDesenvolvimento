@inject LayoutState LayoutState
<div id="view-kanban">
    <div class="kanban" id="kanban-board">
        @if(!LayoutState.KanbanViewToggle)
        {
            <div id="view-lista">
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Projeto</th>
                                <th>Setor</th>
                                <th>Status</th>
                                <th>Prioridade</th>
                                <th>Responsável atual</th>
                                <th>Etapa atual</th>
                                <th>Dias na etapa</th>
                                <th>Dias total</th>
                                <th>Prazo</th>
                                <th>Prog.</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="table-body">
                            @if(CardsManager.CardsDisponiveis.Count() == 0 || CardsDisponiveis == null)
                            {
                                <div class="empty"><i class="ti ti-inbox" style="font-size:24px;display:block;margin-bottom:6px;opacity:.4"></i>Nenhum projeto</div>
                            }
                            else
                            {
                                foreach(var card in CardsDisponiveis)
                                {
                                    <KanbanList CardId="@card.Id"/>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            if(CardsDisponiveis == null) 
            {
                <p>Data inalcançável</p>
            }
            else
            {

                <div class="kanban" id="kanban-board" style="grid-template-columns: repeat(@VisibleColsCount(), minmax(0px, 1fr));">
                    @if(ShowCol(1))
                    {
                        <div class="col" @ondragover:preventDefault @ondrop="() => OnDrop(Status.Backlog)">
                            <div class="col-head">
                                <span class="col-title">Backlog</span>
                                <span class="col-count">@cardsBacklog.Count()</span>
                            </div>
                            @if(cardsBacklog.Count() == 0)
                            {
                                <div class="empty"><i class="ti ti-inbox" style="font-size:24px;display:block;margin-bottom:6px;opacity:.4"></i>Nenhum projeto</div>
                            }
                            else
                            {
                                foreach(var card in cardsBacklog)
                                {
                                    <KanbanCard CardId="@card.Id" OnDragStartCard="OnDragStart" OnCardClick="OnCardClick"/>
                                }
                            }
                        </div>
                    }
                    @if(ShowCol(2))
                    {
                        <div class="col" @ondragover:preventDefault @ondrop="() => OnDrop(Status.EmAndamento)">
                            <div class="col-head">
                                <span class="col-title">Em andamento</span>
                                <span class="col-count">@cardsAndamento.Count()</span>
                            </div>
                            @if(cardsAndamento.Count() == 0)
                            {
                                <div class="empty"><i class="ti ti-inbox" style="font-size:24px;display:block;margin-bottom:6px;opacity:.4"></i>Nenhum projeto</div>
                            }
                            else
                            {
                                foreach(var card in cardsAndamento)
                                {
                                    <KanbanCard CardId="@card.Id" OnDragStartCard="OnDragStart" OnCardClick="OnCardClick"/>
                                }
                            }
                        </div>
                    }
                    @if(ShowCol(3))
                    {
                        <div class="col" @ondragover:preventDefault @ondrop="() => OnDrop(Status.Revisao)">
                            <div class="col-head">
                                <span class="col-title">Revisão</span>
                                <span class="col-count">@cardsRevisao.Count()</span>
                            </div>
                            @if(cardsRevisao.Count() == 0)
                            {
                                <div class="empty"><i class="ti ti-inbox" style="font-size:24px;display:block;margin-bottom:6px;opacity:.4"></i>Nenhum projeto</div>
                            }
                            else
                            {
                                foreach(var card in cardsRevisao)
                                {
                                    <KanbanCard CardId="@card.Id" OnDragStartCard="OnDragStart" OnCardClick="OnCardClick"/>
                                }
                            }
                        </div>
                    }
                    @if(ShowCol(4))
                    {
                        <div class="col" @ondragover:preventDefault @ondrop="() => OnDrop(Status.Concluido)">
                            <div class="col-head">
                                <span class="col-title">Concluído</span>
                                <span class="col-count">@cardsConcluido.Count()</span>
                            </div>
                            @if(cardsConcluido.Count() == 0)
                        {
                            <div class="empty"><i class="ti ti-inbox" style="font-size:24px;display:block;margin-bottom:6px;opacity:.4"></i>Nenhum projeto</div>
                        }
                        else
                        {
                            foreach(var card in cardsConcluido)
                            {
                                    <KanbanCard CardId="@card.Id" OnDragStartCard="OnDragStart" OnCardClick="OnCardClick"/>
                            }
                        }
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public int? EnabledColsIdx { get; set; }
    [Parameter] public EventCallback<string> OnCardClick { get; set; }
    [Parameter] public List<Card>? CardsDisponiveis { get; set; }

    private List<Card> cardsBacklog = new();
    private List<Card> cardsAndamento = new();
    private List<Card> cardsRevisao = new();
    private List<Card> cardsConcluido = new();

    bool ShowCol(int colId)
    {
        return EnabledColsIdx == 0 || EnabledColsIdx == colId;
    }
    int VisibleColsCount()
    {
        if (!EnabledColsIdx.HasValue || EnabledColsIdx == 0)
            return 4;

        return 1;
    }
    protected override void OnParametersSet()
    {
        Refresh();
    }
    protected override void OnInitialized()
    {
        CardsManager.OnChange += Refresh;
        LayoutState.OnChange += Refresh;
    }

    private async void Refresh()
    {
        CardsDisponiveis = CardsDisponiveis!
            .Select(c => CardsManager.TodosCards.FirstOrDefault(t => t.Id == c.Id) ?? c)
            .Where(x => x.DataArquivamento == null).ToList();
        AssembleCards();
        await InvokeAsync(StateHasChanged);
    }

    private void AssembleCards()
    {
        if(CardsDisponiveis != null)
        {
            cardsBacklog = CardsDisponiveis.Where(x => x.CurrentStatus == Status.Backlog).ToList();
            cardsAndamento = CardsDisponiveis.Where(x => x.CurrentStatus == Status.EmAndamento).ToList();
            cardsRevisao = CardsDisponiveis.Where(x => x.CurrentStatus == Status.Revisao).ToList();
            cardsConcluido = CardsDisponiveis.Where(x => x.CurrentStatus == Status.Concluido).ToList();
        }
    }
    public void Dispose()
    {
        CardsManager.OnChange -= Refresh;
        LayoutState.OnChange -= Refresh;
    }

    //drag cards
    private Card? draggedCard;
    void OnDragStart(Card card)
    {
        draggedCard = card;
    }
    async Task OnDrop(Status status)
    {
        if (draggedCard == null || draggedCard.CurrentStatus == status)
            return;
            
        draggedCard.CurrentStatus = status;
        AssembleCards();

        if (status != Status.Backlog && draggedCard.DataComecoProjeto == null)
            draggedCard.DataComecoProjeto = DateTime.Now;
        else if (status == Status.Backlog && draggedCard.DataComecoProjeto != null)
            draggedCard.DataComecoProjeto = null;

        if (status == Status.Concluido && draggedCard.DataConclusao == null)
            draggedCard.DataConclusao = DateTime.Now;
        else if (status != Status.Concluido && draggedCard.DataConclusao != null)
            draggedCard.DataConclusao = null;

        await CardsManager.UpdateCardAsync(draggedCard);

        draggedCard = null;

        await InvokeAsync(StateHasChanged);
    }
}