<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["PainelKanbanDesenvolvimento.styles.css"]" />
    <ImportMap />
    <HeadOutlet @rendermode="InteractiveServer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap"
    rel="stylesheet">
    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/tabler-icons/2.44.0/iconfont/tabler-icons.min.css">
    <style>
            :root {
                --bg: #F5F4F0;
                --surface: #FFFFFF;
                --surface2: #F0EEE9;
                --border: #E2DFD8;
                --border2: #C8C4BB;
                --text: #1A1917;
                --text2: #6B6760;
                --text3: #9E9B96;
                --blue: #185FA5;
                --blue-bg: #E6F1FB;
                --blue-text: #0C447C;
                --green: #3B6D11;
                --green-bg: #EAF3DE;
                --amber: #854F0B;
                --amber-bg: #FAEEDA;
                --red: #A32D2D;
                --red-bg: #FCEBEB;
                --radius: 10px;
                --radius-lg: 14px;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0
            }

            body {
                font-family: 'DM Sans', sans-serif;
                background: var(--bg);
                color: var(--text);
                font-size: 14px;
                line-height: 1.5;
                min-height: 100vh
            }

            button,
            input,
            select,
            textarea {
                font-family: inherit;
                font-size: 14px
            }

            input,
            select,
            textarea {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: 8px 12px;
                color: var(--text);
                width: 100%;
                outline: none;
                transition: border-color .15s
            }

            input:focus,
            select:focus,
            textarea:focus {
                border-color: var(--blue)
            }

            textarea {
                resize: vertical;
                min-height: 70px
            }

            .btn {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                padding: 8px 16px;
                border: 1px solid var(--border2);
                border-radius: var(--radius);
                background: var(--surface);
                color: var(--text);
                cursor: pointer;
                font-size: 13px;
                font-weight: 500;
                transition: all .15s;
                white-space: nowrap
            }

            .btn:hover {
                background: var(--surface2)
            }

            .btn.primary {
                background: var(--blue);
                border-color: var(--blue);
                color: #fff
            }

            .btn.primary:hover {
                background: var(--blue-text);
                border-color: var(--blue-text)
            }

            .btn.sm {
                padding: 5px 10px;
                font-size: 12px
            }

            .btn.icon {
                padding: 6px 8px;
                border-color: transparent;
                background: transparent
            }

            .btn.icon:hover {
                background: var(--surface2);
                border-color: var(--border)
            }

            .badge {
                display: inline-flex;
                align-items: center;
                font-size: 11px;
                font-weight: 500;
                padding: 2px 9px;
                border-radius: 99px;
                white-space: nowrap
            }
            .b-atrasado {
                margin-bottom: 15px;
                background: red;
                color: white
            }
            .b-alta {
                background: var(--red-bg);
                color: var(--red)
            }

            .b-media {
                background: var(--amber-bg);
                color: var(--amber)
            }

            .b-baixa {
                background: var(--green-bg);
                color: var(--green)
            }

            .b-area {
                background: var(--blue-bg);
                color: var(--blue-text)
            }

            .header {
                background: var(--surface);
                border-bottom: 1px solid var(--border);
                padding: 0 24px;
                height: 56px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                position: sticky;
                top: 0;
                z-index: 100
            }

            .header-logo {
                font-size: 15px;
                font-weight: 600;
                color: var(--text);
                display: flex;
                align-items: center;
                gap: 8px
            }

            .header-logo i {
                color: var(--blue);
                font-size: 18px
            }

            .main {
                padding: 20px 24px
            }

            .stats {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
                gap: 10px;
                margin-bottom: 18px;
            }

            .stat {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: var(--radius-lg);
                padding: 14px 18px;
            }

            .stat-label {
                font-size: 11px;
                font-weight: 500;
                color: var(--text3);
                text-transform: uppercase;
                letter-spacing: .04em;
                margin-bottom: 4px;
            }

            .stat-val {
                font-size: 26px;
                font-weight: 600;
                color: var(--text);
                line-height: 1
            }

            .stat-val.red {
                color: var(--red)
            }

            .toolbar {
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 16px;
                flex-wrap: wrap
            }

            .filters {
                display: flex;
                align-items: center;
                gap: 10px;
                flex: 1;
                flex-wrap: wrap
            }

            .fg {
                display: flex;
                align-items: center;
                gap: 6px;
            }

            .fg label {
                font-size: 12px;
                color: var(--text2);
                white-space: nowrap;
                font-weight: 500;
            }

            .fg select {
                width: auto;
                font-size: 12px;
                padding: 6px 10px;
                max-width: 200px;
                overflow-x: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .status-tabs {
                display: flex;
                gap: 5px;
                flex-wrap: wrap
            }

            .stab {
                padding: 6px 14px;
                border: 1px solid var(--border);
                border-radius: 99px;
                background: var(--surface);
                color: var(--text2);
                cursor: pointer;
                font-size: 12px;
                font-weight: 500;
                transition: all .15s
            }

            .stab:hover {
                background: var(--surface2)
            }

            .stab.active {
                background: var(--blue);
                border-color: var(--blue);
                color: #fff
            }

            .view-toggle {
                display: flex;
                border: 1px solid var(--border);
                border-radius: var(--radius);
                overflow: hidden
            }

            .vt-btn {
                padding: 7px 10px;
                background: var(--surface);
                border: none;
                cursor: pointer;
                color: var(--text2);
                font-size: 15px;
                transition: all .15s
            }

            .vt-btn.active {
                background: var(--surface2);
                color: var(--text)
            }

            .kanban {
                display: grid;
                gap: 14px;
                align-items: start
            }

            .col {
                position: sticky;
                top: 70px;
                z-index: 10;
                background: var(--surface2);
                border: 1px solid var(--border);
                border-radius: var(--radius-lg);
                padding: 14px;
                min-height: 80px;
            }

            .col-head {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 12px
            }

            .col-title {
                font-size: 13px;
                font-weight: 600;
                color: var(--text)
            }

            .col-count {
                font-size: 11px;
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 99px;
                padding: 1px 8px;
                color: var(--text2)
            }

            .card {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: var(--radius-lg);
                padding: 16px;
                margin-bottom: 10px;
                cursor: pointer;
                transition: all .15s
            }

            .card:hover {
                border-color: var(--border2);
                box-shadow: 0 4px 12px rgba(0, 0, 0, .07)
            }

            .card:last-child {
                margin-bottom: 0
            }

            .card-title {
                font-size: 14px;
                font-weight: 600;
                color: var(--text);
                margin-bottom: 6px;
                line-height: 1.4
            }

            .card-desc {
                font-size: 12px;
                color: var(--text2);
                margin-bottom: 10px;
                line-height: 1.5
            }

            .card-badges {
                display: flex;
                gap: 5px;
                flex-wrap: wrap;
                margin-bottom: 10px
            }

            .card-divider {
                border: none;
                border-top: 1px solid var(--border);
                margin: 10px 0
            }

            .card-footer {
                display: flex;
                align-items: center;
                gap: 8px;
                flex-wrap: wrap
            }

            .avatar {
                width: 26px;
                height: 26px;
                border-radius: 50%;
                background: var(--blue-bg);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 10px;
                font-weight: 600;
                color: var(--blue-text);
                flex-shrink: 0
            }

            .resp-name {
                font-size: 12px;
                color: var(--text2);
                font-weight: 500
            }

            .etapa-chip {
                font-size: 11px;
                color: var(--text3);
                display: flex;
                align-items: center;
                gap: 3px;
                margin-left: auto
            }

            .dias-wrap {
                margin-top: 10px;
                display: flex;
                gap: 6px;
                flex-wrap: wrap
            }

            .dias-chip {
                display: inline-flex;
                align-items: center;
                gap: 4px;
                background: var(--surface2);
                border: 1px solid var(--border);
                border-radius: 6px;
                padding: 3px 8px;
                font-size: 11px;
                font-family: 'DM Mono', monospace
            }

            .dias-chip.etapa-dias {
                color: var(--blue-text);
                background: var(--blue-bg);
                border-color: #B5D4F4
            }

            .dias-chip.etapa-dias.overdue {
                color: var(--red);
                background: var(--red-bg);
                border-color: #F7C1C1
            }

            .dias-chip.total-dias {
                color: var(--text2)
            }

            .prog-wrap {
                margin-top: 10px;
            }

            .prog-bar {
                width: 100%;
                height: 4px;
                background: var(--surface2);
                border-radius: 99px;
                overflow: hidden;
                display: flex;
            }

            .prog-fill-concluido {
                background: rgb(55, 160, 73);
                height: 100%;
            }

            .prog-fill-andamento {
                background: rgb(255, 177, 59);
                height: 100%;
            }

            .prog-label {
                font-size: 11px;
                color: var(--text3);
                margin-top: 4px;
                font-family: 'DM Mono', monospace
            }

            .empty {
                text-align: center;
                padding: 2.5rem 1rem;
                color: var(--text3);
                font-size: 13px
            }

            .table-wrap {
                overflow-x: auto;
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: var(--radius-lg)
            }

            table {
                width: 100%;
                border-collapse: collapse;
                font-size: 13px
            }

            th {
                text-align: left;
                padding: 10px 14px;
                font-size: 11px;
                font-weight: 600;
                color: var(--text2);
                border-bottom: 1px solid var(--border);
                white-space: nowrap;
                text-transform: uppercase;
                letter-spacing: .04em
            }

            td {
                padding: 11px 14px;
                border-bottom: 1px solid var(--border);
                color: var(--text);
                vertical-align: middle
            }

            tr:last-child td {
                border-bottom: none
            }

            tr:hover td {
                background: var(--surface2)
            }

            .overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(10, 9, 8, .5);
                z-index: 100;
                align-items: flex-start;
                justify-content: center;
                padding: 32px 16px;
                overflow-y: auto
            }

            .overlay.open {
                display: flex
            }

            .modal {
                background: var(--surface);
                border-radius: var(--radius-lg);
                border: 1px solid var(--border);
                padding: 28px;
                width: 100%;
                max-width: 560px;
                margin: auto;
                box-shadow: 0 20px 60px rgba(0, 0, 0, .2)
            }

            .modal-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 20px
            }

            .modal-header h2 {
                font-size: 17px;
                font-weight: 600
            }

            .modal-tabs {
                display: flex;
                border-bottom: 1px solid var(--border);
                margin-bottom: 20px
            }

            .mtab {
                padding: 8px 18px;
                font-size: 13px;
                cursor: pointer;
                border: none;
                background: none;
                color: var(--text2);
                border-bottom: 2px solid transparent;
                margin-bottom: -1px;
                font-weight: 500;
                transition: all .15s
            }

            .mtab.active {
                color: var(--blue);
                border-bottom-color: var(--blue)
            }

            .form-row {
                margin-bottom: 14px
            }

            .form-row label {
                display: block;
                font-size: 12px;
                font-weight: 500;
                color: var(--text2);
                margin-bottom: 5px
            }

            .grid2 {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 12px
            }

            .etapas-list {
                margin-bottom: 14px
            }

            .etapa-row {
                background: var(--surface2);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: 12px 14px;
                margin-bottom: 8px
            }

            .etapa-row-head {
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                gap: 8px;
                margin-bottom: 6px
            }

            .etapa-row-title {
                font-size: 13px;
                font-weight: 600;
                color: var(--text);
                display: flex;
                align-items: center;
                gap: 6px
            }

            .etapa-dot {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                flex-shrink: 0;
                margin-top: 2px
            }

            .ed-pen {
                background: var(--border2)
            }

            .ed-and {
                background: var(--blue)
            }

            .ed-con {
                background: var(--green)
            }

            .etapa-row-meta {
                font-size: 11px;
                color: var(--text3);
                display: flex;
                align-items: center;
                gap: 8px;
                flex-wrap: wrap
            }

            .etapa-add-box {
                background: var(--surface2);
                border: 1px dashed var(--border2);
                border-radius: var(--radius);
                padding: 16px;
                margin-top: 4px
            }

            .add-box-title {
                font-size: 12px;
                font-weight: 600;
                color: var(--text2);
                margin-bottom: 12px;
                text-transform: uppercase;
                letter-spacing: .04em
            }

            .modal-actions {
                display: flex;
                gap: 8px;
                justify-content: flex-end;
                margin-top: 20px;
                padding-top: 16px;
                border-top: 1px solid var(--border)
            }
    </style>
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
